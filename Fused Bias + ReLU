#include <cuda_runtime.h>
#include <iostream>

// ==============================================
// fused kernel Bias Add + ReLU
// y[i] = max(0, x[i] + bias[i % hidden_dim])
// ===============================================

__global__ void bias_relu_kernel(
    const float* x,
    const float* bias,
    float* y,
    int total_elements,
    int hidden_dim
) {
    int i = blockIdx.x * blockDim.x + threadIdx.x;

    if (i < total_elements) {
        int col = i % hidden_dim;

        float value = x[i] + bias[col];

        y[i] = value > 0.0f ? value : 0.0f;
    }
}

int main() {
    int batch_size = 4;
    int hidden_dim = 8;
    int total_elements = batch_size * hidden_dim;

    size_t tensor_size = total_elements * sizeof(float);
    size_t bias_size = hidden_dim * sizeof(float);

    float* h_x = new float[total_elements];
    float* h_bias = new float[hidden_dim];
    float* h_y = new float[total_elements];

    for (int i = 0; i < total_elements; i++) {
        h_x[i] = static_cast<float>(i) - 10.0f;
    }

    for (int i = 0; i < hidden_dim; i++) {
        h_bias[i] = 1.0f;
    }

    float* d_x;
    float* d_bias;
    float* d_y;

    cudaMalloc(&d_x, tensor_size);
    cudaMalloc(&d_bias, bias_size);
    cudaMalloc(&d_y, tensor_size);

    cudaMemcpy(d_x, h_x, tensor_size, cudaMemcpyHostToDevice);
    cudaMemcpy(d_bias, h_bias, bias_size, cudaMemcpyHostToDevice);

    bias_relu_kernel<<<blocks, threadsPerBlock>>> (
        d_x,
        d_bias,
        d_y,
        total_elements,
        hidden_dim
    );

    cudaDeviceSynchronize();

    cudaMemcpy(h_y, d_y, tensor_size, cudaMemcpyDeviceToHost);

    for (int i = 0; i < total_elements; i++) {
        std::cout << "y[" << i << "] = " << h_y[i] << std::endl;
    }

    cudaFree(d_x);
    cudaFree(d_bias);
    cudaFree(d_y);

    delete[] h_x;
    delete[] h_bias;
    delete[] h_y;

    return 0;
}
